rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().role == "ADMIN";
    }

    function isManagerOrAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().role in ["ADMIN", "MANAGER"];
    }


    // ── Users ──────────────────────────────────────────────────────────────────
    // • Anyone signed in can read all user profiles (needed for Staff Directory,
    //   swap request display, shortage alert matching, etc.)
    // • Users can create their own doc on first sign-in.
    // • ADMIN can update anyone. Managers can update employees in their branch
    //   (name, phone, position, branch) but NOT the role field.
    // • Only ADMIN can delete user docs.
    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && request.auth.uid == userId;

      allow update: if isSignedIn() && (
        // ADMIN can do anything
        isAdmin()
        // MANAGER can edit employees in their own branch — but NOT role
        || (
          userDoc().role == "MANAGER"
          && resource.data.branch == userDoc().branch
          && resource.data.role == "EMPLOYEE"
          && !("role" in request.resource.data.diff(resource.data).affectedKeys())
        )
        // User can update their own non-role fields (profile panel)
        || (
          request.auth.uid == userId
          && !("role" in request.resource.data.diff(resource.data).affectedKeys())
        )
        // Bootstrap: allow first ADMIN self-promotion
        || (
          request.auth.uid == userId
          && request.resource.data.role == "ADMIN"
          && resource.data.role != "ADMIN"
        )
      );

      allow delete: if isAdmin();
    }

    // ── Shifts ─────────────────────────────────────────────────────────────────
    // • All signed-in users can read (employees need to see their own shifts).
    // • ADMIN can write any shift.
    // • MANAGER can only write shifts in their own branch.
    match /shifts/{id} {
      allow read: if isSignedIn();
      allow create: if isManagerOrAdmin() && (
        isAdmin() || request.resource.data.branchId == userDoc().branch
      );
      allow update, delete: if isManagerOrAdmin() && (
        isAdmin() || resource.data.branchId == userDoc().branch
      );
    }

    // ── Tasks ──────────────────────────────────────────────────────────────────
    // • All read. ADMIN/MANAGER write.
    match /tasks/{id} {
      allow read: if isSignedIn();
      allow write: if isManagerOrAdmin();
    }

    // ── Inventory ──────────────────────────────────────────────────────────────
    // • All signed-in users can read inventory.
    // • ADMIN can write any inventory item.
    // • MANAGER can only write inventory items for their own branch.
    match /inventory/{id} {
      allow read: if isSignedIn();
      allow create: if isManagerOrAdmin()
        && request.resource.data.branchId is string
        && (isAdmin() || request.resource.data.branchId == userDoc().branch);
      allow update, delete: if isManagerOrAdmin()
        && (isAdmin() || resource.data.branchId == userDoc().branch);
    }

    // ── Branches ───────────────────────────────────────────────────────────────
    // • All signed-in users can read (needed for dropdowns, etc.).
    // • Only ADMIN can create/update/delete branches.
    match /branches/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Shortage Alerts ────────────────────────────────────────────────────────
    // • All signed-in users can read (employees need to see open alerts to respond).
    // • All signed-in users can create (sick leave triggers a create from employees).
    // • Only ADMIN or MANAGER can update status (FILLED / CANCELLED).
    match /shortageAlerts/{alertId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isManagerOrAdmin();
      allow delete: if isAdmin();
    }

    // ── Shortage Responses ─────────────────────────────────────────────────────
    // • All signed-in users can read (managers review who responded).
    // • Employees create their own response; they may update only their own.
    match /shortageResponses/{responseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isAdmin() || resource.data.employeeUid == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ── Swap Requests ──────────────────────────────────────────────────────────
    // • All signed-in users can read.
    // • Any signed-in user can create (employee initiates the swap).
    // • MANAGER or ADMIN can update status (approve/reject).
    // • The requester can cancel their own PENDING request.
    match /swapRequests/{swapId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isManagerOrAdmin()
        || (request.auth.uid == resource.data.requesterId && resource.data.status == "PENDING")
      );
      allow delete: if isAdmin();
    }

    // ── Taxi Requests ──────────────────────────────────────────────────────────
    // • All signed-in can read and create.
    // • MANAGER/ADMIN can update (approve/reject). Employee can cancel their own.
    match /taxis/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isManagerOrAdmin()
        || request.auth.uid == resource.data.staffId
      );
      allow delete: if isAdmin();
    }

    // ── Notifications ──────────────────────────────────────────────────────────
    // • Users can only read their own notifications or broadcast ("all") ones.
    // • Anyone signed-in can create (system notifications from client actions).
    // • Users can mark their own notifications as read (update).
    match /notifications/{id} {
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid || resource.data.uid == "all"
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.uid == request.auth.uid || resource.data.uid == "all"
      );
      allow delete: if isAdmin();
    }

    // ── Forecast ───────────────────────────────────────────────────────────────
    match /forecast/{id} {
      allow read: if isSignedIn();
      allow write: if isManagerOrAdmin();
    }

    // ── AI Cache ───────────────────────────────────────────────────────────────
    // Only accessible via Firebase Admin SDK (Cloud Functions / server).
    // No client access allowed.
    match /aiCache/{cacheKey} {
      allow read, write: if false;
    }

    // ── Catch-all ──────────────────────────────────────────────────────────────
    // Deny everything not explicitly matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
